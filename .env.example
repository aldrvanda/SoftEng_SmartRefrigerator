# Copy this file to .env.local and fill in your values

# MongoDB connection string (from MongoDB Atlas or local instance)
# Example Atlas: mongodb+srv://username:password@cluster.mongodb.net/
# Example local: mongodb://localhost:27017
DB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/

# App URL (used for redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
